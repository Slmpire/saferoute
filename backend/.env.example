PORT=3000
NODE_ENV=development

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-client-email@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_DATABASE_URL=https://your-project-id.firebaseio.com

# Africa's Talking (SMS + Call escalation)
AT_API_KEY=your-africas-talking-api-key
AT_USERNAME=your-africas-talking-username
AT_SENDER_ID=SafeRoute

# Alert timing windows (in minutes)
WINDOW_HOME_TO_SCHOOL=60
WINDOW_SCHOOL_TO_HOME=90
ALERT_ESCALATION_MINUTES=15
SECURITY_ESCALATION_MINUTES=30

# Security org contact
SECURITY_ORG_PHONE=+2348000000000
SECURITY_ORG_EMAIL=security@example.com

# JWT (for device API keys – hardware phase)
DEVICE_SECRET=replace-with-strong-secret